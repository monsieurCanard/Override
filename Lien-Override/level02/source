#include <stdio.h>
#include <stdlib.h>
#include <string.h>

/*
 * Decompiled / rewritten source for the exploited level02 binary.
 * Vulnerability used in the notes: printf(username) is called without a
 * fixed format string when authentication fails, producing a format-string leak.
 */
int main(int argc, char **argv)
{
    char username[100] = {0};
    char password[41] = {0};
    char input_password[100] = {0};
    FILE *fp = NULL;
    int read_count = 0;

    (void)argc;
    (void)argv;

    fp = fopen("/home/users/level03/.pass", "r");
    if (fp == NULL)
    {
        fwrite("ERROR: failed to open password file\n", 1, 36, stderr);
        exit(1);
    }

    read_count = fread(password, 1, 41, fp);
    password[strcspn(password, "\n")] = '\0';
    if (read_count != 41)
    {
        fwrite("ERROR: failed to read password file\n", 1, 36, stderr);
        fwrite("ERROR: failed to read password file\n", 1, 36, stderr);
        exit(1);
    }
    fclose(fp);

    puts("===== [ Secure Access System v1.0 ] =====");
    puts("/***************************************\\");
    puts("| You must login to access this system. |");
    puts("\\**************************************/");

    printf("--[ Username: ");
    fgets(username, 100, stdin);
    username[strcspn(username, "\n")] = '\0';

    printf("--[ Password: ");
    fgets(input_password, 100, stdin);
    input_password[strcspn(input_password, "\n")] = '\0';

    puts("*****************************************");

    if (strncmp(password, input_password, 41) == 0)
    {
        printf("Greetings, %s!\n", username);
        system("/bin/sh");
        return 0;
    }

    printf(username);          /* format-string vulnerability */
    puts(" does not have access!");
    exit(1);
}
